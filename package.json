{
  "name": "lumen",
  "version": "0.1.0",
  "private": true,
  "description": "Lumen — Netflix+IMDB hybrid with Apple Liquid Glass design language",
  "scripts": {
    "dev": "next dev",
    "build": "next build && serwist build serwist.config.mjs",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:setup": "tsx --env-file=.env.local scripts/db-bootstrap.ts",
    "seed:catalog": "tsx --env-file=.env.local scripts/seed-catalog.ts",
    "embed:titles": "tsx scripts/embed-titles.ts",
    "ingest:cc0": "tsx --env-file=.env.local scripts/ingest-cc0.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.73",
    "@clerk/nextjs": "^6.20.0",
    "@clerk/themes": "^2.2.0",
    "@hookform/resolvers": "^3.9.1",
    "@mux/mux-node": "^14.0.1",
    "@mux/mux-player-react": "^3.2.0",
    "@neondatabase/serverless": "^0.10.4",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@serwist/next": "^9.5.11",
    "@vercel/analytics": "^1.4.0",
    "@vercel/speed-insights": "^1.1.0",
    "ai": "^6.0.182",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^11.13.5",
    "next": "^16.0.0",
    "node-vibrant": "^4.0.3",
    "pgvector": "^0.2.0",
    "posthog-js": "^1.194.0",
    "posthog-node": "^4.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.1",
    "svix": "^1.42.0",
    "tailwind-merge": "^2.5.5",
    "three": "^0.171.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "@serwist/cli": "^9.5.11",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.171.0",
    "drizzle-kit": "^0.30.1",
    "postcss": "^8.5.0",
    "serwist": "^9.5.11",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
