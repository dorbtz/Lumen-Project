# Lumen — environment variables
# After `vercel link` and Marketplace provisioning, run:
#   NODE_OPTIONS=--use-system-ca vercel env pull .env.local
# That will populate the marketplace-provided vars automatically.

# --- Neon Postgres (Marketplace) ---
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_PRISMA_URL=

# --- Upstash Redis (Marketplace) ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Clerk (Marketplace) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/profiles
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/profiles

# --- Mux (Marketplace) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SIGNING_SECRET=

# --- TMDB (manual — get key from https://www.themoviedb.org/settings/api) ---
TMDB_API_KEY=
TMDB_API_READ_ACCESS_TOKEN=

# --- Hugging Face Inference (manual — get token from https://huggingface.co/settings/tokens) ---
HF_API_TOKEN=

# --- PostHog (manual — get key from https://app.posthog.com/project/settings) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Lumen-internal ---
LUMEN_PROFILE_COOKIE_SECRET= # 32+ char random string, used to sign lumen_active_profile cookie
